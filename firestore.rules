rules_version = '2';

// Pravidla pro sdílený badmintonový dataset.
// Nasaď přes Firebase konzoli (Firestore Database → Rules) nebo Firebase CLI.
service cloud.firestore {
  match /databases/{database}/documents {

    // Jeden společný dokument badminton/shared – čtení i zápis jen pro lidi na seznamu.
    // Přidávej/odebírej e-maily party tady a pokaždé dej Publish.
    match /badminton/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email in [
          "dduchek@elinkx.cz"
          // , "kamarad@example.com"
          // , "dalsi@example.com"
        ];
    }
  }
}
