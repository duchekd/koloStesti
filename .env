#Číslo verze je předáno parametrem při buildu prostředí
VITE_APP_VERSION=${build_number}

#Název/ID aplikace. Musí být shodné s hodnotou name v package.json
VITE_APP_NAME="randomizer"

#Access token pouze pro lokální vývoj. Po startu aplikace bude token nastaven přesunut do umístění v sessionStorage.
VITE_APP_ACCESS_TOKEN=""

#Relativní cesta ke konfiguračním souborům aplikace
VITE_APP_CONFIG_PATH="/"
